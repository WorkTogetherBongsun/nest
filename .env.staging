# [스테이징(결함 테스트) 개발 환경용 환경변수]
NODE_ENV=staging

# --------------------------
# Database Settings (PostgreSQL)
# --------------------------
DB_HOST=staging-db.internal.aws.com
DB_PORT=5432
DB_USER=staging_test_user
DB_PASSWORD=staging_secret_password
DB_NAME=mesapphub_staging

# --------------------------
# JWT / Security (예시)
# --------------------------
JWT_SECRET=super_secret_staging_key
JWT_EXPIRATION=1d
